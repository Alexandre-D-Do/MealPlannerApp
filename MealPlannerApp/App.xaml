<Application x:Class="MealPlannerApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MealPlannerApp"
             xmlns:vm="clr-namespace:MealPlannerApp.ViewModels"
             xmlns:views="clr-namespace:MealPlannerApp.Views"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/ApplicationWindowStyles.xaml"/>
                <ResourceDictionary Source="/Styles/CloseButtonStyles.xaml"/>
                <ResourceDictionary Source="/Styles/TitleBarButtonStyles.xaml"/>
                <ResourceDictionary Source="/Styles/DarkListViewStyles.xaml"/>
                <ResourceDictionary Source="/Styles/ApplicationButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:AddIngredientViewModel}">
                <views:AddIngredientView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
