<Window Style="{StaticResource ApplicationWindow}"
        x:Class="MealPlannerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schsemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MealPlannerApp"
        xmlns:views="clr-namespace:MealPlannerApp.Views"
        xmlns:vms="clr-namespace:MealPlannerApp.ViewModels"
        mc:Ignorable="d"
        WindowStyle="None"
        xmlns:userControls="clr-namespace:MealPlannerApp.UserControls" 
        Title="Meal Planner" Height="600" Width="1000">


   

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <userControls:TitleBar Grid.Row="0"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="1">
            <Grid Margin="20, 10" MaxWidth="600">
                <Grid.Resources>
                    <DataTemplate DataType="{x:Type vms:MainWindowViewModel}">
                        <views:MainWindowView/>
                    </DataTemplate>
                </Grid.Resources>
                <ContentControl Margin="25,0,25,0"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Content="{Binding CurrentViewModel}" />
            </Grid>
        </ScrollViewer>



    </Grid>
</Window>
